# Puerto donde se ejecutará la API.
PORT=3000

# Conexión MySQL utilizada exclusivamente por la API.
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=sistema_contable_pinax

# Autenticación mediante JSON Web Tokens.
# JWT_SECRET debe generarse individualmente en cada entorno.
JWT_SECRET=
JWT_EXPIRES_IN=2h
JWT_ISSUER=pinax-api
JWT_AUDIENCE=pinax-frontend

# Costo utilizado para generar contraseñas bcrypt.
BCRYPT_ROUNDS=12
