# Identidad del frontend Laravel.
APP_NAME="Pinax Frontend"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://127.0.0.1:8000

# Configuración regional.
APP_LOCALE=es
APP_FALLBACK_LOCALE=es
APP_FAKER_LOCALE=es_ES

# Laravel trabajará localmente sin base de datos propia.
APP_MAINTENANCE_DRIVER=file

# Registros de desarrollo.
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# La sesión se almacena en archivos locales.
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# El frontend no utiliza base de datos para caché ni tareas.
CACHE_STORE=file
QUEUE_CONNECTION=sync
FILESYSTEM_DISK=local

# Dirección de la API externa de Pinax.
PINAX_API_URL=http://127.0.0.1:3000/api
PINAX_API_TIMEOUT=10

# Nombre disponible para Vite.
VITE_APP_NAME="${APP_NAME}"
